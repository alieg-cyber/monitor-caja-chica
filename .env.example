# ============================================================
# ARCHIVO DE VARIABLES DE ENTORNO - COPIA COMO .env
# ============================================================

# ID de tu Google Spreadsheet (extraído de la URL)
# Ejemplo: https://docs.google.com/spreadsheets/d/1AbCdEfGhIjKlMnOpQrStUvWxYz/edit
# SPREADSHEET_ID sería: 1AbCdEfGhIjKlMnOpQrStUvWxYz
SPREADSHEET_ID=tu_spreadsheet_id_aqui

# Ruta al archivo de credenciales del Service Account de Google
CREDENTIALS_FILE=credentials.json

# Contraseña SMTP para envío de alertas por email (opcional)
# NO se almacena en Google Sheets, solo aquí localmente
SMTP_PASSWORD=
